generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model BlogPost {
  id          Int      @id @default(autoincrement())
  titulo      String
  autor       String
  dataHorario DateTime @default(now())
  descricao   String
  imagem      String?
  publicado   Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("blog_posts")
}

model Categoria {
  id       Int       @id @default(autoincrement())
  nome     String    @unique
  produtos Produto[]

  @@map("categorias")
}

model Servidor {
  id       Int       @id @default(autoincrement())
  nome     String    @unique
  ip       String
  porta    Int       @default(25565)
  produtos Produto[]

  @@map("servidores")
}

model Produto {
  id          Int       @id @default(autoincrement())
  nome        String
  preco       Float
  descricao   String?
  categoriaId Int
  servidorId  Int
  ativo       Boolean   @default(true)
  createdAt   DateTime  @default(now())
  comando     String    @default("lp user %player% parent add vip")
  imagem      String?
  categoria   Categoria @relation(fields: [categoriaId], references: [id])
  servidor    Servidor  @relation(fields: [servidorId], references: [id])

  @@map("produtos")
}

model Cupom {
  id       Int       @id @default(autoincrement())
  codigo   String    @unique
  desconto Int
  ativo    Boolean   @default(true)
  expira   DateTime?

  @@map("cupons")
}

model Equipe {
  id    Int    @id @default(autoincrement())
  nick  String @unique
  cargo String

  @@map("equipe")
}

model ServerGoal {
  id          Int      @id @default(1)
  target      Float    @default(1000.0)
  current     Float    @default(0.0)
  lastUpdated DateTime @default(now())

  @@map("servidor_metas")
}

model Pagamento {
  id        Int      @id @default(autoincrement())
  valor     Float
  status    String   @default("PAID")
  createdAt DateTime @default(now())

  @@map("pagamentos")
}

model Entrega {
  id          Int       @id @default(autoincrement())
  jogador     String
  produto     String
  comando     String
  servidor    String
  status      String    @default("PENDING")
  dataCriacao DateTime  @default(now()) @map("data_criacao")
  dataEntrega DateTime? @map("data_entrega")

  @@map("entregas_pendentes")
}

model Configuracao {
  chave String @id
  valor String

  @@map("configuracoes")
}
